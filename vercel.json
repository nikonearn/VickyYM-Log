{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run typecheck:libs && PORT=3000 BASE_PATH=/ pnpm --filter @workspace/acctmarket run build",
  "outputDirectory": "artifacts/acctmarket/dist/public",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    { "source": "/((?!api(?:/|$)).*)", "destination": "/index.html" }
  ]
}
